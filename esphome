  - platform: template
    name: "BMS1 Balancing Cells"
    update_interval: 5s
    lambda: |-
      uint16_t bal = (uint16_t) id(bms1_balance_raw).state;
      if (bal == 0) return {"Balancing: geen"};
      std::string out = "Balancing: cellen ";
      bool first = true;
      for (int i = 0; i < 16; i++) {
        if (bal & (1 << i)) {
          if (!first) out += ", ";
          out += std::to_string(i + 1);
          first = false;
        }
      }
      return {out};

