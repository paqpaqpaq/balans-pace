text_sensor:
  - platform: pace_bms
    pace_bms_id: master_bms
    raw_status:
      name: "BMS1 Raw Status"
    warning_status:
      name: "BMS1 Warning Status"
    protection_status:
      name: "BMS1 Protection Status"
    fault_status:
      name: "BMS1 Fault Status"
    system_status:
      name: "BMS1 System Status"
      filters:
        - lambda: |
            std::string out = x;
            for (auto& token : {"DFET On; ", "CFET On; ", "DFET On", "CFET On"}) {
              auto pos = out.find(token);
              if (pos != std::string::npos) out.erase(pos, strlen(token));
            }
            while (out.size() >= 2 && out.substr(out.size()-2) == "; ")
              out.erase(out.size()-2);
            return out;
    balancing_status:
      name: "BMS1 Balancing Status"
    configuration_status:
      name: "BMS1 Configuration Status"

