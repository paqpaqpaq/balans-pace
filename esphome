logger:
  level: VERBOSE
  baud_rate: 0
  tx_buffer_size: 512

web_server:
  port: 80

external_components:
  - source:
      type: local
      path: components
    components: [ pace_bms ]

uart:
  id: uart_0
  baud_rate: 9600
  tx_pin: GPIO23
  rx_pin: GPIO19
  rx_buffer_size: 2048

pace_bms:
  - id: master_bms
    address: 2
    uart_id: uart_0
    flow_control_pin: GPIO18
    update_interval: 10s
    request_throttle: 50ms
    response_timeout: 6000ms
    protocol_commandset: 0x25
    protocol_version: 0x20
    type: MASTER
    slave_query_mode: RELAY
    rx_buffer_size: 2048

  - id: slave_bms_3
    address: 3
    type: SLAVE
    master_bms_id: master_bms

  - id: slave_bms_4
    address: 4
    type: SLAVE
    master_bms_id: master_bms

